# Copy to .env and fill in values

# Postgres (matches docker-compose defaults)
DATABASE_URL=postgresql+asyncpg://research:research@localhost:5432/research

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Search tool — https://tavily.com (or set EXA_API_KEY and swap in engine/tools/search.py)
TAVILY_API_KEY=

# CORS — comma-separated list of allowed frontend origins (defaults to localhost:3000)
CORS_ORIGINS=http://localhost:3000

# Optional: LangSmith tracing for the eval harness's faithfulness judge calls
# https://smith.langchain.com
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=
# LANGCHAIN_PROJECT=deep-research-eval
